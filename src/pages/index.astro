<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hostazone Horse Agistment</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-stone-100 text-stone-800 font-sans antialiased">

    <!-- Header / Hero Section -->
    <header class="relative bg-stone-900 text-white py-24 px-6 text-center bg-cover bg-center" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1534567153574-2b12153a87f0?q=80&w=1200');">
        <div class="max-w-3xl mx-auto">
            <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">Hostazone Agistment</h1>
            <p class="text-xl md:text-2xl text-stone-300 font-light mb-8">Premium care and exceptional facilities for your equine partners.</p>
            <a href="#contact" class="bg-amber-600 hover:bg-amber-700 text-white font-semibold px-8 py-3 rounded-full transition duration-300 inline-block shadow-lg">Enquire Today</a>
        </div>
    </header>

    <!-- Main Content Container -->
    <main class="max-w-6xl mx-auto px-4 py-12">

        <!-- About Section -->
        <section class="mb-16 text-center max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-stone-900 mb-4">Welcome to Hostazone</h2>
            <p class="text-lg text-stone-600 leading-relaxed">
                Located in a peaceful rural setting, Hostazone offers top-tier horse agistment services. We pride ourselves on providing a safe, clean, and stress-free environment tailored to meet the individual dietary, exercise, and health requirements of every horse under our care.
            </p>
        </section>

        <hr class="border-stone-200 mb-16">

        <!-- Services & Pricing -->
        <section class="mb-16">
            <h2 class="text-3xl font-bold text-stone-900 text-center mb-10">Our Packages</h2>
            <div class="grid md:grid-cols-2 gap-8">
                
                <!-- Full Care Package -->
                <div class="bg-white p-8 rounded-2xl shadow-md border border-stone-200 flex flex-col justify-between">
                    <div>
                        <h3 class="text-2xl font-bold text-stone-900 mb-2">Full Service Agistment</h3>
                        <p class="text-amber-700 font-semibold text-xl mb-4">$180 per week</p>
                        <p class="text-stone-600 mb-6">Complete peace of mind. We handle absolutely everything your horse needs daily.</p>
                        <ul class="space-y-3 text-stone-700 mb-8">
                            <li class="flex items-center">✓ Individual private paddocks with safe fencing</li>
                            <li class="flex items-center">✓ Twice daily premium hard feeds & quality hay</li>
                            <li class="flex items-center">✓ Rugging and unrugging tailored to changing weather</li>
                            <li class="flex items-center">✓ Daily hoof checking and wellness monitoring</li>
                        </ul>
                    </div>
                    <a href="#contact" class="w-full text-center bg-stone-800 hover:bg-stone-900 text-white font-medium py-3 rounded-xl transition">Select Full Care</a>
                </div>

                <!-- Part Care Package -->
                <div class="bg-white p-8 rounded-2xl shadow-md border border-stone-200 flex flex-col justify-between">
                    <div>
                        <h3 class="text-2xl font-bold text-stone-900 mb-2">Part Service Agistment</h3>
                        <p class="text-amber-700 font-semibold text-xl mb-4">$110 per week</p>
                        <p class="text-stone-600 mb-6">A flexible option for hands-on owners who want premium facilities with shared duties.</p>
                        <ul class="space-y-3 text-stone-700 mb-8">
                            <li class="flex items-center">✓ Shared or private paddock options</li>
                            <li class="flex items-center">✓ Once daily feeding (feed provided by owner)</li>
                            <li class="flex items-center">✓ Automated water troughs in all paddocks</li>
                            <li class="flex items-center">✓ Full access to all facility riding spaces</li>
                        </ul>
                    </div>
                    <a href="#contact" class="w-full text-center bg-stone-200 hover:bg-stone-300 text-stone-800 font-medium py-3 rounded-xl transition">Select Part Care</a>
                </div>

            </div>
        </section>

        <hr class="border-stone-200 mb-16">

        <!-- Facilities -->
        <section class="mb-16">
            <h2 class="text-3xl font-bold text-stone-900 text-center mb-10">Our Facilities</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-200">
                    <h4 class="font-bold text-lg mb-2">All-Weather Arena</h4>
                    <p class="text-stone-600 text-sm">Fully fenced, professional-grade sand arena with floodlights for evening riding.</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-200">
                    <h4 class="font-bold text-lg mb-2">Secure Tack Room</h4>
                    <p class="text-stone-600 text-sm">Lockable, dry, and clean storage space for all your saddles, bridles, and equipment.</p>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-200">
                    <h4 class="font-bold text-lg mb-2">Wash Bays</h4>
                    <p class="text-stone-600 text-sm">Equipped with rubber matting and high-pressure hot/cold water hookups.</p>
                </div>
            </div>
        </section>

        <!-- Contact Form Section -->
        <section id="contact" class="bg-stone-900 text-white p-8 md:p-12 rounded-3xl shadow-xl max-w-4xl mx-auto">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold mb-2">Get in Touch</h2>
                <p class="text-stone-400">Have questions or want to book a tour of the property? Drop us a line.</p>
            </div>
            <form class="space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-stone-300 mb-2">Your Name</label>
                        <input type="text" required class="w-full bg-stone-800 border border-stone-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-amber-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-stone-300 mb-2">Email Address</label>
                        <input type="email" required class="w-full bg-stone-800 border border-stone-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-amber-500">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-stone-300 mb-2">Message / Requirements</label>
                    <textarea rows="4" required class="w-full bg-stone-800 border border-stone-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-amber-500" placeholder="Tell us about your horse..."></textarea>
                </div>
                <div class="text-center">
                    <button type="submit" class="bg-amber-600 hover:bg-amber-700 text-white font-semibold px-10 py-3 rounded-xl transition shadow-md w-full md:w-auto">Submit Enquiry</button>
                </div>
            </form>
        </section>

    </main>

    <!-- Footer -->
    <footer class="text-center py-8 text-stone-500 text-sm border-t border-stone-200 mt-12 bg-white">
        <p>&copy; 2026 Hostazone Agistment. All rights reserved.</p>
    </footer>

</body>
</html>
